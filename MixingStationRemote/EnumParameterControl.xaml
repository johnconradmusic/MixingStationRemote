<local:ParameterControlBase x:Class="MixingStationRemote.EnumParameterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             PreviewKeyDown="UserControl_PreviewKeyDown"
                          xmlns:local="clr-namespace:MixingStationRemote"
Focusable="True" Width="50" Height="32" IsTabStop="True">
    <StackPanel Margin="2">
        <TextBlock x:Name="label" Focusable="False" FontSize="8" Text="{Binding Caption}"/>
        <TextBox x:Name="textBox" Background="LightGreen" Focusable="False"/>
    </StackPanel>
</local:ParameterControlBase>