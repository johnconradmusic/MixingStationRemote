<Window x:Class="MixingStationRemote.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MixingStationRemote"
        mc:Ignorable="d"
        Title="ConnectionWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <StackPanel>
		<TextBox x:Name="txtStationUrl" Text="http://localhost:8080" />
		<!-- user types the mixing-station address -->
		<ComboBox x:Name="cmbModels" DisplayMemberPath="name" IsEnabled="False" SelectionChanged="cmbModels_SelectionChanged"/>
		<Button x:Name="btnSearch" Content="Search" IsEnabled="False" Click="btnSearch_Click"/>
		<Button x:Name="btnRefresh" Content="Refresh Results" Click="btnRefresh_Click"/>
		<ListBox x:Name="lstMixers" DisplayMemberPath="name" />
		<Button x:Name="btnConnect" Content="Connect" IsEnabled="False" Click="btnConnect_Click"/>
	</StackPanel>
</Window>
